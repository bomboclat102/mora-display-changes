---
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import companyImage1 from "../assets/images/Placeholder-company.png";
import companyImage2 from "../assets/images/Placeholder-company2.png";
import companyImage3 from "../assets/images/Placeholder-company3.png";
---

<Layout title="Company">
  <Header />

  <main class="bg-black text-white">
    <section class="mx-auto w-full max-w-[1800px] px-4 py-8 md:px-8 md:py-12 lg:px-12">
      <div class="flex w-full flex-col gap-6 md:gap-8 lg:gap-10">
        <Image
          src={companyImage1}
          alt="Company reference 1"
          class="company-image"
        />

        <Image
          src={companyImage2}
          alt="Company reference 2"
          class="company-image"
        />

        <Image
          src={companyImage3}
          alt="Company reference 3"
          class="company-image"
        />
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .company-image {
    width: 100%;
    display: block;
    height: auto;
    min-width: 0;
    user-select: none;
    -webkit-user-select: none;
    -webkit-touch-callout: none;
    pointer-events: none;
  }
</style>
