---
import { Image } from "astro:assets";
import logoImage from "../assets/logo.png";

const base = import.meta.env.BASE_URL;
---

<header
  class="site-header sticky top-0 z-50 flex items-center justify-between bg-black/90 px-8 py-8 backdrop-blur-sm md:px-16"
>
  <a href={base} class="text-lg font-semibold tracking-wide text-white">
    <Image src={logoImage} alt="Logo" class="h-full w-auto" loading="eager" />
  </a>

  <button
    type="button"
    class="menu-toggle group relative z-50 flex cursor-pointer items-center gap-3"
    data-menu-toggle
    aria-label="Open menu"
    aria-expanded="false"
    aria-controls="site-menu-panel"
  >
    <span class="flex flex-col gap-[6px]">
      <span class="block h-[2px] w-7 bg-[var(--color-accent)]"></span>
      <span class="block h-[2px] w-7 bg-[var(--color-accent)]"></span>
      <span class="block h-[2px] w-7 bg-[var(--color-accent)]"></span>
    </span>
    <span class="text-base font-medium text-white" data-menu-label>Menu</span>
  </button>

  <div
    id="site-menu-panel"
    class="pointer-events-none fixed inset-0 z-40 bg-black/80 opacity-0 transition-opacity duration-300"
    data-menu-panel
    aria-hidden="true"
  >
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(255,106,0,0.12),transparent_45%),radial-gradient(circle_at_bottom_left,rgba(255,106,0,0.08),transparent_40%)]"></div>

    <div class="relative flex h-full flex-col justify-between px-8 py-8 text-white md:px-16 md:py-12">
      <div class="text-xs uppercase tracking-[0.35em] text-white/40">Navigation</div>

      <nav class="max-w-3xl">
        <ul class="space-y-5 text-4xl font-light uppercase tracking-[0.12em] md:text-6xl">
          <li><a class="menu-link text-white transition-colors hover:text-[var(--color-accent)]" href={`${base}#hero`}>Home</a></li>
          <li><a class="menu-link text-white transition-colors hover:text-[var(--color-accent)]" href={`${base}#projects`}>Projects</a></li>
          <li><a class="menu-link text-white transition-colors hover:text-[var(--color-accent)]" href={`${base}company`}>Company</a></li>
          <li><a class="menu-link text-white transition-colors hover:text-[var(--color-accent)]" href={`${base}#gallery`}>Gallery</a></li>
          <li><a class="menu-link text-white transition-colors hover:text-[var(--color-accent)]" href={`${base}#contact`}>Contact</a></li>
        </ul>
      </nav>

    </div>
  </div>
</header>

<style>
  .site-header.is-menu-open {
    background: rgba(0, 0, 0, 0.98);
  }

  .site-header.is-menu-open [data-menu-panel] {
    pointer-events: auto;
    opacity: 1;
  }

  :global(body.menu-open > :not(.site-header)) {
    filter: blur(10px) brightness(0.7);
    pointer-events: none;
    user-select: none;
    transition: filter 0.3s ease;
  }

</style>

<script>
  const header = document.querySelector<HTMLElement>(".site-header");
  const menuPanel = header?.querySelector<HTMLElement>("[data-menu-panel]");
  const menuToggles = header?.querySelectorAll<HTMLButtonElement>("[data-menu-toggle]");
  const menuLinks = header?.querySelectorAll<HTMLAnchorElement>(".menu-link");

  const setMenuOpen = (open: boolean) => {
    if (!header || !menuPanel) return;

    header.classList.toggle("is-menu-open", open);
    document.body.classList.toggle("menu-open", open);
    menuPanel.setAttribute("aria-hidden", String(!open));
    document.body.style.overflow = open ? "hidden" : "";

    header.querySelectorAll<HTMLButtonElement>("[data-menu-toggle]").forEach((button) => {
      button.setAttribute("aria-expanded", String(open));
      button.setAttribute("aria-label", open ? "Close menu" : "Open menu");
      const label = button.querySelector<HTMLElement>("[data-menu-label]");
      if (label) {
        label.textContent = open ? "Close" : "Menu";
      }
    });
  };

  menuToggles?.forEach((button) => {
    button.addEventListener("click", () => {
      setMenuOpen(!header?.classList.contains("is-menu-open"));
    });
  });

  menuLinks?.forEach((link) => {
    link.addEventListener("click", () => setMenuOpen(false));
  });

  menuPanel?.addEventListener("click", (event) => {
    if (event.target === menuPanel) {
      setMenuOpen(false);
    }
  });

  window.addEventListener("keydown", (event) => {
    if (event.key === "Escape") {
      setMenuOpen(false);
    }
  });
</script>
