import { Image } from "astro:assets";
import mapImage from "../assets/images/map.png";
---

<section id="projects" class="relative mx-auto max-w-[1336px] px-8 py-20 text-white md:px-16">
  <projects-map>
    <div class="relative mx-auto aspect-[4096/2304] w-full">
      <Image
        src={mapImage}
        alt="World map showing project locations"
        class="absolute inset-0 h-full w-full object-contain"
      />

      {
        locations.map((loc) => (
          <button
            type="button"
            class="map-dot absolute h-[15px] w-[15px] -translate-x-1/2 -translate-y-1/2 cursor-pointer rounded-full bg-[#ffa500] transition-transform duration-150 hover:scale-125 focus:outline-none focus-visible:ring-2 focus-visible:ring-white"
            style={`left:${loc.x}%; top:${loc.y}%`}
            data-id={loc.id}
            aria-label={`View projects in ${loc.label}`}
          />
        ))
      }
    </div>

    <div class="mt-12">
      <h2 class="projects-heading text-5xl font-thin text-[var(--color-accent)]">
        Projects
      </h2>

      <div
        class="projects-list mt-2 max-w-[520px] text-sm leading-relaxed text-white/70"
      >
        <p data-default-text>
          Select a location on the map to view the fairs associated with it.
        </p>
      </div>
    </div>

    <script
      type="application/json"
      data-locations
      set:html={JSON.stringify(locations)}
    />
  </projects-map>
</section>

<style>
  .map-dot.is-active {
    box-shadow: 0 0 0 4px rgba(255, 255, 255, 0.35);
  }
</style>

<script>
  class ProjectsMap extends HTMLElement {
    private locations: Array<{
      id: string;
      label: string;
      projects: { name: string; dates: string; place: string }[];
    }> = [];
    private listEl!: HTMLElement;
    private dots!: NodeListOf<HTMLButtonElement>;

    connectedCallback() {
      const dataScript = this.querySelector<HTMLScriptElement>(
        "script[data-locations]",
      );
      this.locations = dataScript
        ? JSON.parse(dataScript.textContent || "[]")
        : [];
      this.listEl = this.querySelector(".projects-list")!;
      this.dots = this.querySelectorAll(".map-dot");

      this.dots.forEach((dot) => {
        dot.addEventListener("click", () =>
          this.selectLocation(dot.dataset.id!),
        );
      });
    }

    selectLocation(id: string) {
      this.dots.forEach((d) =>
        d.classList.toggle("is-active", d.dataset.id === id),
      );

      const loc = this.locations.find((l) => l.id === id);
      if (!loc) return;

      const projectColumns = [] as typeof loc.projects[];
      for (let index = 0; index < loc.projects.length; index += 8) {
        projectColumns.push(loc.projects.slice(index, index + 8));
      }

      this.listEl.innerHTML = `
        <h3 class="mb-3 text-2xl font-medium text-white">${loc.label}</h3>
        <div class="grid gap-8 ${projectColumns.length > 1 ? "sm:grid-cols-2" : ""}">
          ${projectColumns
            .map(
              (column) => `
            <ul class="space-y-2">
              ${column
                .map(
                  (p) => `
                <li class="border-b border-white/10 pb-2">
                  <span class="block font-medium text-white">${p.name}</span>
                  <span class="block text-white/50">${p.place}</span>
                </li>`,
                )
                .join("")}
            </ul>`,
            )
            .join("")}
        </div>
      `;
    }
  }

  customElements.define("projects-map", ProjectsMap);
</script>
